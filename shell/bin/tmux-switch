#!/usr/bin/env bash
# Session switcher with inline create:
#   - highlight an existing session + Enter → switch to it
#   - type a name that matches no session + Enter → create a new session with that name
#   - Ctrl+N inside fzf → force-create a session with the typed query (bypasses matches)
# The fzf header updates live to indicate which action Enter will perform.
# Used by the tmux Ctrl+S binding (inside tmux) and the `ts` zsh function
# (anywhere — outside tmux it falls back to `tmux attach` instead of switch-client,
# which only works with an active client).
set -euo pipefail

# Inside tmux, switch the current client; outside, attach. switch-client is a
# no-op without a client, so plain `ts` from a fresh shell would otherwise fail.
attach_or_switch() {
  local name="$1"
  if [ -n "${TMUX:-}" ]; then
    tmux switch-client -t "$name"
  else
    tmux attach -t "$name"
  fi
}

HINT='enter: switch · type a new name to create · ctrl-n: force create'

# Dynamic "+ new session: <query>" header needs transform-header + FZF_MATCH_COUNT
# (fzf 0.53.0+, Jul 2024). Older fzf (Ubuntu 22.04 ships 0.29, 24.04 ships 0.44)
# rejects the bind outright, so gate on version — older fzf keeps the static hint.
dyn_bind=()
fzf_num=$(fzf --version 2>/dev/null | awk '{split($1,a,"."); printf "%d%03d%03d", a[1], a[2], a[3]}')
if [ "${fzf_num:-0}" -ge 53000 ]; then
  dyn_bind=(--bind "change:transform-header:[ \"\$FZF_MATCH_COUNT\" = 0 ] && [ -n \"\$FZF_QUERY\" ] && printf '\033[33m+ new session: %s\033[0m — enter to create' \"\$FZF_QUERY\" || printf '%s' '$HINT'")
fi

# fzf exits 1 on "no match" even when the user pressed Enter or Ctrl+N with a
# typed query — that's exactly our create-new-session path, so don't treat
# exit 1 as failure. Only 130 (Ctrl+C / Esc) should abort.
set +e
result=$(
  "${HOME}/.dotfiles/shell/bin/tmux-ls" | fzf \
    --ansi \
    --reverse \
    --no-sort \
    --print-query \
    --expect=ctrl-n \
    --prompt='Session: ' \
    --header="$HINT" \
    "${dyn_bind[@]}" \
    --preview='tmux capture-pane -ep -t {-1} 2>/dev/null' \
    --preview-window=right:60%
)
rc=$?
set -e
[ "$rc" -eq 130 ] && exit 0
[ "$rc" -ge 2 ] && exit 0

query=$(printf '%s\n' "$result" | sed -n '1p')
key=$(printf '%s\n' "$result" | sed -n '2p')
selection=$(printf '%s\n' "$result" | sed -n '3p')

if [ "$key" = "ctrl-n" ]; then
  name="$query"
  [ -z "$name" ] && [ -n "$selection" ] && name=$(printf '%s' "$selection" | awk '{print $NF}')
  [ -z "$name" ] && exit 0
  tmux new-session -d -s "$name" 2>/dev/null || true
  attach_or_switch "$name"
elif [ -n "$selection" ]; then
  name=$(printf '%s' "$selection" | awk '{print $NF}')
  attach_or_switch "$name"
elif [ -n "$query" ]; then
  tmux new-session -d -s "$query"
  attach_or_switch "$query"
fi
