#!/usr/bin/env bash
# Kill one or more tmux sessions via fzf (multi-select with Tab).
# Current session is excluded — killing it would close Ghostty.
# Used by Ctrl+K (Ghostty) and Ctrl+Q (Termius alias).
set -euo pipefail
# `|| true`: tmux exits non-zero when the server isn't running, but we
# still want to drop into the picker (which will be empty and let the
# user Esc out cleanly).
current=$(tmux display-message -p '#S' 2>/dev/null || true)
# `|| true` on the pipe end: fzf exits 130 when the user Escs out;
# that's a normal cancel, not a failure.
tmux-ls | grep -v " ${current} " | fzf --ansi --reverse --no-sort --multi \
  --prompt='Kill session: ' \
  --preview='tmux capture-pane -ep -t {-1}' \
  --preview-window=right:60% \
  | awk '{print $NF}' \
  | while read -r s; do
      tmux kill-session -t "$s" && echo "killed: $s"
    done \
  || true
