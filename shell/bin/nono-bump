#!/usr/bin/env bash
# Bump the pinned nono version and SHA256 hashes in install.conf.yaml.
# Usage:
#   nono-bump            # bump to latest GitHub release
#   nono-bump 0.38.0     # bump to a specific version
#
# Fetches the requested release's amd64 + arm64 .deb assets, computes their
# SHA256, shows a diff against install.conf.yaml, and rewrites the pinned
# NONO_VERSION / NONO_SHA256_{AMD64,ARM64} values on confirmation.
#
# Upstream only signs the .tar.gz builds in SHA256SUMS.txt (not .deb), so we
# compute and pin ourselves. This script is the only supported path to bump
# those pins — don't edit them by hand.
set -euo pipefail

REPO="always-further/nono"
CONF="${HOME}/.dotfiles/install.conf.yaml"

[ -f "$CONF" ] || { echo "error: $CONF not found" >&2; exit 1; }
command -v curl >/dev/null || { echo "error: curl required" >&2; exit 1; }
command -v shasum >/dev/null || { echo "error: shasum required" >&2; exit 1; }

target="${1:-latest}"
if [ "$target" = "latest" ]; then
  if command -v gh >/dev/null 2>&1; then
    version=$(gh api "repos/${REPO}/releases/latest" --jq '.tag_name' | sed 's/^v//')
  else
    # Fallback: follow the /releases/latest redirect to extract the tag.
    version=$(curl -fsSI "https://github.com/${REPO}/releases/latest" \
      | awk -F'/' 'BEGIN{IGNORECASE=1} /^location:/ {gsub(/\r/,"",$NF); print $NF}' \
      | sed 's/^v//')
  fi
else
  version="${target#v}"
fi

[ -n "$version" ] || { echo "error: could not resolve version" >&2; exit 1; }

echo "→ resolving nono v${version}"

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

declare -A sha
for arch in amd64 arm64; do
  url="https://github.com/${REPO}/releases/download/v${version}/nono-cli_${version}_${arch}.deb"
  echo "→ downloading ${arch}"
  if ! curl -fsSL -o "$tmp/nono_${arch}.deb" "$url"; then
    echo "error: download failed for $arch — release v${version} missing that asset?" >&2
    exit 1
  fi
  sha[$arch]=$(shasum -a 256 "$tmp/nono_${arch}.deb" | awk '{print $1}')
done

echo
echo "version: $version"
echo "amd64:   ${sha[amd64]}"
echo "arm64:   ${sha[arm64]}"
echo

staged=$(mktemp)
sed -e "s|^\( *NONO_VERSION=\)[0-9A-Za-z.+-]*|\1${version}|" \
    -e "s|^\( *NONO_SHA256_AMD64=\)[0-9a-f]*|\1${sha[amd64]}|" \
    -e "s|^\( *NONO_SHA256_ARM64=\)[0-9a-f]*|\1${sha[arm64]}|" \
    "$CONF" > "$staged"

if diff -q "$CONF" "$staged" >/dev/null; then
  echo "no change — pins already match"
  rm -f "$staged"
  exit 0
fi

diff -u "$CONF" "$staged" || true
echo

read -r -p "apply to $CONF? [y/N] " ok
if [ "$ok" = "y" ] || [ "$ok" = "Y" ]; then
  mv "$staged" "$CONF"
  echo "✓ pins updated"
else
  rm -f "$staged"
  echo "aborted"
  exit 1
fi
