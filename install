#!/usr/bin/env bash
set -e

CONFIG="install.conf.yaml"
DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
# `pwd -P` resolves symlinks so BASEDIR lands on the physical checkout path
# even when the script is invoked via ~/.dotfiles (which dotfiles-switch
# repoints at the active worktree). Without -P, BASEDIR resolves to
# ~/.dotfiles itself, and `ln -sfn "$BASEDIR" ~/.dotfiles` below creates a
# self-referencing symlink loop.
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"

cd "${BASEDIR}"

# Create ~/.dotfiles symlink early so dd-dotfiles install can rely on it
ln -sfn "${BASEDIR}" "${HOME}/.dotfiles"

# Bootstrap all submodules (dotbot, dotbot-git, dotbot-brew, .oh-my-zsh) before running dotbot
git submodule update --init --recursive

# Defensive: replace any directory-level symlinks at our managed link
# destinations with a fresh empty dir. Old versions of this config used
# `path: xbar/plugins` (no /*) which made dotbot create a directory-level
# symlink — and once that exists, dotbot's per-file `force: true` glob will
# happily delete files at the symlink's TARGET (often tracked source files
# in this very repo) before recreating self-referential symlinks. Catch
# this once at install time so old machines self-heal on next run.
_xbar_plugins_dest="$HOME/Library/Application Support/xbar/plugins"
if [ -L "$_xbar_plugins_dest" ]; then
  echo "Defusing legacy directory-level symlink: $_xbar_plugins_dest"
  rm "$_xbar_plugins_dest"
  mkdir -p "$_xbar_plugins_dest"
fi
unset _xbar_plugins_dest

"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" --plugin-dir dotbot-git -c "${CONFIG}" "${@}"

# Linuxbrew bootstrap — on Linux, install Homebrew if missing so the Brewfile
# step below has something to run. macOS laptops come with brew from the
# developer image, so this is a Linux-only concern. Pinned SHA for
# reproducibility; bump with care. NONINTERACTIVE=1 skips the sudo prompt and
# the press-RETURN gate (workspaces provision headlessly).
if [[ "$(uname)" != "Darwin" ]] && ! command -v brew >/dev/null 2>&1 \
   && [[ ! -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  BREW_INSTALL_SHA="63bc55817caea9f8fe210485ce5e1e90c7b96339"
  echo "Installing Homebrew (pinned @ ${BREW_INSTALL_SHA:0:7})..."
  NONINTERACTIVE=1 /bin/bash -c \
    "$(curl -fsSL "https://raw.githubusercontent.com/Homebrew/install/${BREW_INSTALL_SHA}/install.sh")"
fi
# Load shellenv so dotbot-brew below finds `brew` on PATH. The ~/.zshrc
# managed block already prepends the linuxbrew prefix for interactive shells,
# but this `install` script runs non-interactively.
if [[ "$(uname)" != "Darwin" && -x /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Brewfile — runs on both macOS and Linux. Cask-only entries are gated with
# `if OS.mac?` in the Brewfile itself so `brew bundle` is a no-op for them
# on Linux. Always runs when brew is available: bottle/cask caching makes
# repeat passes near-instant when nothing has changed, so the install pipeline
# stays uniform whether it's a fresh clone or a worktree switch — every run
# ends in the same final state.
if command -v brew >/dev/null 2>&1; then
  "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" --plugin-dir dotbot-brew -c <(echo '- brewfile: [Brewfile]') "${@}"
fi
