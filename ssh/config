# Public SSH config — included by ~/.ssh/config
# Usage: Include ~/.ssh/config.dotfiles

Host *
  SetEnv TERM=xterm-256color # cmux/ghostty: remote servers lack xterm-ghostty terminfo
  AddressFamily inet
  Compression yes
  ControlMaster auto
  ControlPath /tmp/ssh*mux*%h*%p*%r
  ControlPersist 10m
  ServerAliveInterval 30

