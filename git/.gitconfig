# This is Git's per-user configuration file.
[user]
name = luphaz
email = luphaz@users.noreply.github.com
# signingkey configured per-machine (dd-dotfiles overlay or 1Password)

[url "git@github.com:"]
insteadOf = https://github.com/
insteadOf = git://github.com/

[pull]
ff = only
rebase = true

[url "git://"]
insteadOf = https://

[init]
defaultBranch = main

[push]
default = simple
	autoSetupRemote = true

[core]
excludesFile = ~/.gitignore
attributesfile = ~/.gitattributes

[commit]
# gpgsign enabled via dd-dotfiles overlay (requires signing key)
verbose = true

# Machine-specific signing config (1Password SSH on macOS, etc.)
# No-op if ~/.dd-dotfiles is not present.
[include]
  path = ~/.dd-dotfiles/git/.gitconfig

[core]
editor = tvim
ignorecase = false
pager = delta # https://github.com/dandavison/delta

[diff]
tool = nvimdiff
colorMoved = zebra
submodule = log

[difftool "nvimdiff"]
cmd = nvim -d $LOCAL $REMOTE

[merge]
tool = nvimdiff
conflictstyle = diff3

[mergetool "nvimdiff"]
cmd = nvim -d $LOCAL $BASE $REMOTE $MERGED -c 'wincmd J'

[alias]
m = machete
ca = commit --amend --no-edit
cam = commit --amend
caa = commit --amend --no-edit -a
caam = commit --amend -a
ll = log --oneline --graph --all --decorate
po = remote prune origin --dry-run
pof = remote prune origin
pf = push --force-with-lease
pff = push --force
root = rev-parse --show-toplevel
sync = "!sync() { trunk=$(git remote show origin | sed -n '/HEAD branch/s/.*: //p'); git machete traverse -yW; awk '/^  .*rebase=no/{print $1}' < $(git rev-parse --show-toplevel)/.git/machete | xargs -I {} bash -c 'git switch {} && git merge '\"$trunk\"; git machete traverse -yw --push; }; sync"
cpr = "!cpr() { git machete github create-pr --draft && git machete anno $(git machete anno) rebase=no; }; cpr"

[rebase]
updateRefs = true

[interactive]
diffFilter = delta --color-only

[delta]
navigate = true # use n and N to move between diff sections
light = false   # set to true if you're in a terminal w/ a light background color (e.g. the default macOS terminal)
side-by-side = true
line-numbers = true

[status]
submoduleSummary = true

[protocol "file"]
allow = always

[fetch]
prune = true

[absorb]
autoStageIfNothingStaged = true
[credential "https://github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/opt/homebrew/bin/gh auth git-credential
